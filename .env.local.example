# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Painel do Supabase > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# E-mails transacionais (Resend > API Keys)
RESEND_API_KEY=re_xxxxxxxx

# Confirmação de fornecedores (módulo de e-mail)
# Service role key: Painel do Supabase > Settings > API > service_role (secreta!)
SUPABASE_SERVICE_ROLE_KEY=
# Qualquer string aleatória longa — protege a rota /api/cron/confirmacoes
CRON_SECRET=
# URL pública do app (usada nos links dos e-mails). Em dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Remetente dos e-mails. Sem domínio verificado no Resend, use o padrão
# onboarding@resend.dev (só entrega para o e-mail da conta Resend).
EMAIL_FROM=Vela <onboarding@resend.dev>
